#include <WiFi.h>
#include <WebServer.h>
#include <DHT.h>

#define DHTPIN 4
#define DHTTYPE DHT11

const char* ssid     = "YOUR_WIFI_NAME";       // <-- CHANGE THIS
const char* password = "YOUR_WIFI_PASSWORD";   // <-- CHANGE THIS

WebServer server(80);
DHT dht(DHTPIN, DHTTYPE);

float threshold = 40.0;
bool  autoMode  = true;
bool  fanState  = false;

